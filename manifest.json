{
  "manifest_version": 3,
  "name": "Full Chat Screenshot for WhatsApp Web",
  "version": "1.0.1",
  "description": "One-click capture of a full WhatsApp Web conversation as a stitched PNG, from the first message. No scrolling. 100% local.",
  "homepage_url": "https://github.com/jenstools/full-chat-screenshot-for-whatsapp-web",
  "minimum_chrome_version": "109",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture full WhatsApp chat",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
